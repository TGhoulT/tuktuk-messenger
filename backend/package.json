{
    "name": "tuk-tuk-backend",
    "version": "1.0.0",
    "scripts": {
        "dev": "ts-node-dev --respawn --transpile-only src/main.ts",
        "build": "tsc",
        "start": "node dist/main.js",
        "typeorm": "typeorm-ts-node-commonjs",
        "migration:generate": "npm run typeorm migration:generate -- -d src/database/data-source.ts",
        "migration:run": "npm run typeorm migration:run -- -d src/database/data-source.ts"
    },
    "dependencies": {
        "@uku/audio-waveform-node": "^0.3.2",
        "axios": "^1.16.0",
        "bcrypt": "^5.1.1",
        "bull": "^4.16.5",
        "class-transformer": "^0.5.1",
        "class-validator": "^0.15.1",
        "cors": "^2.8.5",
        "dotenv": "^16.4.5",
        "express": "^4.18.2",
        "express-rate-limit": "^7.1.5",
        "fluent-ffmpeg": "^2.1.3",
        "geolite2-redist": "^3.1.3",
        "helmet": "^8.1.0",
        "ioredis": "^5.10.1",
        "jsonwebtoken": "^9.0.3",
        "maxmind": "^5.0.6",
        "multer": "^2.1.1",
        "node-cron": "^4.2.1",
        "passport": "^0.7.0",
        "passport-jwt": "^4.0.1",
        "pg": "^8.11.3",
        "reflect-metadata": "^0.2.1",
        "sharp": "^0.34.5",
        "socket.io": "^4.8.3",
        "typeorm": "^0.3.28",
        "uuid": "^9.0.1"
    },
    "devDependencies": {
        "@types/bcrypt": "^5.0.2",
        "@types/bull": "^3.15.9",
        "@types/cors": "^2.8.19",
        "@types/express": "^4.17.21",
        "@types/fluent-ffmpeg": "^2.1.28",
        "@types/jsonwebtoken": "^9.0.5",
        "@types/multer": "^2.1.0",
        "@types/node": "^20.11.0",
        "@types/node-cron": "^3.0.11",
        "@types/passport-jwt": "^4.0.1",
        "@types/sharp": "^0.31.1",
        "@types/socket.io": "^3.0.1",
        "ts-node-dev": "^2.0.0",
        "typescript": "^5.3.3"
    }
}
