PORT=3000
NODE_ENV=development

DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=tuk-tuk

JWT_ACCESS_SECRET=your_access_secret_here
JWT_REFRESH_SECRET=your_refresh_secret_here
JWT_ACCESS_EXPIRES_IN=15m

# Срок жизни refresh-токена (в днях)
DEFAULT_SESSION_LIFETIME_DAYS=7
MAX_SESSION_LIFETIME_DAYS=365

MASTER_KEY=your_master_key_here
MASTER_SALT=your_master_salt_here

# Необязательные сервисы
KLIPY_API_KEY=your_klipy_api_key
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# Redis (для очередей, опционально)
REDIS_HOST=localhost
REDIS_PORT=6379

# Настройки защиты от брутфорса
AUTH_MAX_FAILED_ATTEMPTS=5
AUTH_BLOCK_DURATION_MINUTES=10
AUTH_BLOCK_ESCALATION=true